STEP 1 — MYSQL SETUP
Create Tables
CREATE TABLE transactions (
    DATE DATE,
    STORE_NBR INT,
    LYLTY_CARD_NBR INT,
    PROD_NAME VARCHAR(100),
    PROD_QTY INT,
    TOT_SALES INT
);

CREATE TABLE customers (
    LYLTY_CARD_NBR INT,
    LIFESTAGE VARCHAR(50),
    PREMIUM_CUSTOMER VARCHAR(10)
);

STEP 2 — EXTRACT DATA (PYTHON)
import pandas as pd
import mysql.connector

conn = mysql.connector.connect(
    host="localhost",
    user="root",
    password="password",
    database="retail_db"
)

query = "SELECT * FROM transactions"
df = pd.read_sql(query, conn)

cust_query = "SELECT * FROM customers"
