Example-3
import pandas as pd
data = {
    "property_id": [1,2,3,4,5,6],
    "locality": ["BTM", "Whitefield", "BTM", None, "Indiranagar", "BTM"],
    "rent": [20000, 50000, None, 40000, 60000, 30000],
    "size": [1000, 1200, 900, 1100, 1500, None],
    "owner": ["Ravi", "Sita", "Ravi", "John", "Anu", "Ravi"]
}
df = pd.DataFrame(data)

df.head()
df.info()
df.isnull().sum()
df = df.dropna()
df['rent'] = df['rent'].fillna(df['rent'].mean())
df['size'] = df['size'].fillna(df['size'].mean())
df['locality'] = df['locality'].fillna("Unknown")

df['price_per_sqft'] = df['rent'] / df['size']
import numpy as np
df['category'] = np.where(df['rent'] > 40000, "High", "Low")

df.groupby('locality')['rent'].mean()
df['locality'].value_counts()
df.sort_values(by='rent', ascending=False).head(3) 
df.groupby('owner')['property_id'].count() # Owner wise total properties

df['avg_rent'] = df.groupby('locality')['rent'].transform('mean') # Add avg rent column
df['comparison'] = np.where(df['rent'] > df['avg_rent'], "Above Avg", "Below Avg") # Compare rent
df['rank'] = df.groupby('locality')['rent'].rank(ascending=False) # Rank Properties per locality
df[df['rank'] == 1] # Top Property per locality
df[df['category'] == "High"] # High rent Properties

df.to_csv("cleaned_properties.csv", index=False) # Save Output
