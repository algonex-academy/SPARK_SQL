STEP 2 — Draw YOUR FIRST PLOT
import pandas as pd
import matplotlib.pyplot as plt

data = {
    "STORE_NBR": [1,2,3],
    "TOT_SALES": [200,300,250]
}
df = pd.DataFrame(data)

plt.plot(df["STORE_NBR"], df["TOT_SALES"])
plt.show()

''' Ikkada X-axis -> STORE_NBR
Y-axis -> TOTAL SALES '''

STEP 3 — BAR CHART (MOST USED)
# Compare categories (stores, products)
store_sales = df.groupby("STORE_NBR")["TOT_SALES"].sum()

plt.bar(store_sales.index, store_sales.values)
plt.show() # Which store performs best?

# plt.bar(x, y)
stores = [1, 2, 3]
sales = [200, 300, 250]

plt.bar(stores, sales)
plt.show()
# Sales per store
# Revenue per product


STEP 4 — LINE CHART
# Trends over time
df["DATE"] = pd.to_datetime(df["DATE"])

daily_sales = df.groupby("DATE")["TOT_SALES"].sum()

plt.plot(daily_sales.index, daily_sales.values)
plt.show() # Sales trend over time

# plt.plot(x, y)
months = [1, 2, 3]
sales = [200, 300, 250]

plt.plot(months, sales)
plt.show()
# Monthly sales, growth trends

STEP 5 — PIE CHART
plt.pie(values, labels=labels, autopct="%1.1f%%")

# Contribution %
sales = df.groupby("STORE_NBR")["TOT_SALES"].sum()

plt.pie(sales.values, labels=sales.index, autopct="%1.1f%%")
plt.show() # Which store contributes most?


