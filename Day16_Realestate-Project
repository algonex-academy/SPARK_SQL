Correlated Subquery
-- 11. Find properties with rent higher than their locality average
SELECT p.property_id, p.locality, p.rent
FROM properties p
WHERE rent >
(
SELECT AVG(rent)
FROM properties
WHERE locality = p.locality
);

Self Join
-- 12. Find properties in the same locality with higher rent
SELECT p1.property_id, p2.property_id
FROM properties p1
JOIN properties p2
ON p1.locality = p2.locality
AND p1.rent < p2.rent;

