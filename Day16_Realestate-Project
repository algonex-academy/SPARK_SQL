CREATE DATABASE real_estate_project;
USE real_estate_project;

CREATE TABLE properties (
property_id VARCHAR(50) PRIMARY KEY,
type VARCHAR(20),
activation_date DATE,
bathroom INT,
floor INT,
total_floor INT,
furnishing VARCHAR(20),
gym BOOLEAN,
latitude FLOAT,
longitude FLOAT,
lease_type VARCHAR(20),
lift BOOLEAN,
locality VARCHAR(100),
parking BOOLEAN,
property_age INT,
property_size INT,
swimming_pool BOOLEAN,
pin_code INT,
rent INT,
deposit INT,
building_type VARCHAR(50)
);

SELECT * FROM properties;
