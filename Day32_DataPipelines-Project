3. Step-by-step Implementation
Step 1 -> Database Setup
CREATE DATABASE real_estate_project;
USE real_estate_project;

CREATE TABLE properties (
    property_id INT PRIMARY KEY,
    locality VARCHAR(100),
    rent INT,
    property_size INT,
    furnishing VARCHAR(50),
    property_age INT
);

Step 2 — Extract Layer (extract.py)
import pandas as pd
import mysql.connector
from config.db_config import db_config

def extract_data():
    conn = mysql.connector.connect(**db_config)
    query = "SELECT * FROM properties"
    df = pd.read_sql(query, conn)
    conn.close()
    return df

Step 3 — Transform Layer (transform.py)
def transform_data(df):
    df = df.dropna()

    df['price_per_sqft'] = df['rent'] / df['property_size']

    def rent_category(rent):
        if rent > 70000:
            return 'High'
        elif rent > 40000:
            return 'Medium'
        else:
            return 'Low'

    df['rent_category'] = df['rent'].apply(rent_category)

    return df

Step 4 - Load Layer (load.py)
import mysql.connector
from config.db_config import db_config

def load_data(df):
    conn = mysql.connector.connect(**db_config)
    cursor = conn.cursor()

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS properties_analytics (
        property_id INT,
        locality VARCHAR(100),
        rent INT,
        property_size INT,
        price_per_sqft FLOAT,
        rent_category VARCHAR(20)
    )
    """)

    insert_query = """
    INSERT INTO properties_analytics
    VALUES (%s, %s, %s, %s, %s, %s)
    """

    for _, row in df.iterrows():
        cursor.execute(insert_query, tuple(row))

    conn.commit()
    conn.close()

Step 5 — Pipeline Orchestrator (pipeline.py)
from extract import extract_data
from transform import transform_data
from load import load_data

def run_pipeline():
    df = extract_data()
    df = transform_data(df)
    load_data(df)
    print("Pipeline executed successfully")

if __name__ == "__main__":
    run_pipeline()

