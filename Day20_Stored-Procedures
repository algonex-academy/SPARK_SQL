Example 3tho nerchukoo – IN Parameter
-- Find properties above given rent (Mee projectloo use cheskondi)
DELIMITER //

CREATE PROCEDURE properties_by_rent(IN min_rent INT)
BEGIN

SELECT property_id, locality, rent
FROM properties
WHERE rent > min_rent;
END //

DELIMITER ;

CALL properties_by_rent(40000); -- This makes the procedure dynamic(Later result ni change cheyochu with inputs)

Example 4 – OUT Parameter
-- Return average rent
DELIMITER //
CREATE PROCEDURE get_avg_rent(OUT avg_value DECIMAL(10,2))
BEGIN
SELECT AVG(rent) INTO avg_value
FROM properties;
END //
DELIMITER ;

CALL get_avg_rent(@avg);
SELECT @avg;

INOUT Parameter: INOUT in a Stored Procedure (SP) means the parameter works as both input and output
- receive a value(Input) when the procedure starts
- return a modified value(Output) after the procedure ends
So INOUT is used when you want to pass a value into the procedure, change it inside and get the updated value back ardaminda

CREATE PROCEDURE procedure_name(INOUT variable_name datatype)
BEGIN
    -- logic
END;

Ex 6: Suppose you pass a rent value and the procedure increases it by 10%
DELIMITER //

CREATE PROCEDURE increase_rent(INOUT rent_value DECIMAL(10,2))
BEGIN
    SET rent_value = rent_value + (rent_value * 0.10);
END //

DELIMITER ;

SET @rent = 50000;
CALL increase_rent(@rent);
SELECT @rent;

