4. FULL OUTER JOIN (MySQL Workaround)
-> Returns rows that exist in either table (matched + unmatched both sides)
SELECT u.user_id, u.name, o.order_id
FROM users u
LEFT JOIN orders o ON u.user_id = o.user_id
UNION
SELECT u.user_id, u.name, o.order_id
FROM users u
RIGHT JOIN orders o ON u.user_id = o.user_id;

5. SELF JOIN (Table Joined With Itself)
-> Joins a table to itself using aliases

SELECT e.name AS employee, m.name AS manager
FROM employees e
LEFT JOIN employees m
  ON e.manager_id = m.emp_id;

6. CROSS JOIN (All Combinations anochu)
Returns every combination of rows from both tables
SELECT u.name, p.plan_name
FROM users u
CROSS JOIN plans p;

Ex: Find users with no orders
SELECT u.user_id, u.name
FROM users u
LEFT JOIN orders o ON u.user_id = o.user_id
WHERE o.order_id IS NULL;

Ex:2 Top users by total spend

SELECT u.user_id, u.name, SUM(o.amount) AS total_spent
FROM users u
JOIN orders o ON u.user_id = o.user_id
GROUP BY u.user_id, u.name
ORDER BY total_spent DESC;
