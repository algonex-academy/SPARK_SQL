-> Returns all rows from right table and matching rows from left table

𝗦𝗘𝗟𝗘𝗖𝗧 𝘂.𝘂𝘀𝗲𝗿_𝗶𝗱, 𝘂.𝗻𝗮𝗺𝗲, 𝗼.𝗼𝗿𝗱𝗲𝗿_𝗶𝗱
𝗙𝗥𝗢𝗠 𝘂𝘀𝗲𝗿𝘀 𝘂
𝗥𝗜𝗚𝗛𝗧 𝗝𝗢𝗜𝗡 𝗼𝗿𝗱𝗲𝗿𝘀 𝗼
𝗢𝗡 𝘂.𝘂𝘀𝗲𝗿_𝗶𝗱 = 𝗼.𝘂𝘀𝗲𝗿_𝗶𝗱;

-- Same as swapping tables in LEFT JOIN but prefer LEFT JOIN for clarity
SELECT u.user_id, u.name, o.order_id
FROM users u
