2. LEFT JOIN (All Left + Matching Right) - Find Missing Data – Super Important in Industry
Returns all rows from left table and matching rows from right table
If no match in right-> right columns = NULL

𝗦𝗘𝗟𝗘𝗖𝗧 𝘂.𝘂𝘀𝗲𝗿_𝗶𝗱, 𝘂.𝗻𝗮𝗺𝗲, 𝗼.𝗼𝗿𝗱𝗲𝗿_𝗶𝗱
𝗙𝗥𝗢𝗠 𝘂𝘀𝗲𝗿𝘀 𝘂
𝗟𝗘𝗙𝗧 𝗝𝗢𝗜𝗡 𝗼𝗿𝗱𝗲𝗿𝘀 𝗼
𝗢𝗡 𝘂.𝘂𝘀𝗲𝗿_𝗶𝗱 = 𝗼.𝘂𝘀𝗲𝗿_𝗶𝗱;

Ex: Find users who never placed an order (LEFT JOIN + NULL filter)
SELECT u.user_id, u.name
FROM users u
LEFT JOIN orders o ON u.user_id = o.user_id
WHERE o.order_id IS NULL;
 -- Show me users even if they have no orders

Ex: Find orders that don’t have payments (Data quality check kosam)
SELECT o.order_id, o.amount
FROM orders o
LEFT JOIN payments p ON o.order_id = p.order_id
WHERE p.payment_id IS NULL;

Ex: Revenue per user (JOIN + GROUP BY)
SELECT u.user_id, u.name, SUM(o.amount) AS revenue
FROM users u
JOIN orders o ON u.user_id = o.user_id
WHERE o.status = 'PAID'
GROUP BY u.user_id, u.name
ORDER BY revenue DESC;

Ex: Users with failed payments (Multi-table JOIN vadthunaam)
SELECT DISTINCT u.user_id, u.name
FROM users u
JOIN orders o ON u.user_id = o.user_id
JOIN payments p ON o.order_id = p.order_id
WHERE p.status = 'FAILED';

LEFT JOIN Done Right (Avoid the #1 Fresher Bug)
Wrong (turns LEFT into INNER):
SELECT u.user_id
FROM users u
LEFT JOIN orders o ON u.user_id = o.user_id
WHERE o.status = 'PAID';   -- filters NULLs -> becomes INNER JOIN

Correct (filter in ON):
SELECT u.user_id
FROM users u
LEFT JOIN orders o
  ON u.user_id = o.user_id AND o.status = 'PAID';
-- Filters for the right table go in ON for LEFT JOIN

Ex: Find Employees Without Projects (LEFT JOIN + NULL filter) -> Who is on bench /unassigned
SELECT e.emp_id, e.name
FROM employees e
LEFT JOIN employee_projects ep ON e.emp_id = ep.emp_id
WHERE ep.project_id IS NULL;
-- Resource planning, utilization reports

Ex: Show all employees, even those not assigned to any project -- LEFT JOIN
SELECT e.emp_id, e.name, p.project_name
FROM employees e
LEFT JOIN employee_projects ep ON e.emp_id = ep.emp_id
LEFT JOIN projects p ON ep.project_id = p.project_id;

# The "Production-Ready" Template
SELECT
  u.user_id,
  u.name,
  SUM(o.amount) AS revenue
FROM users u
JOIN orders o ON u.user_id = o.user_id
LEFT JOIN payments p ON o.order_id = p.order_id
WHERE o.created_at >= CURDATE() - INTERVAL 30 DAY
GROUP BY u.user_id, u.name
ORDER BY revenue DESC
LIMIT 20;

